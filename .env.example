# ==============================================
# FindStudioSpace — Required Environment Variables
# ==============================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_ID=price_...
STRIPE_PRICE_FEATURED_ID=price_...

# --- Email (Resend) ---
RESEND_API_KEY=re_...

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.findstudiospace.com
NEXT_PUBLIC_DIRECTORY_ID=findstudiospace
NEXT_PUBLIC_DIRECTORY_NAME=FindStudioSpace
NEXT_PUBLIC_DIRECTORY_DOMAIN=findstudiospace.com
NEXT_PUBLIC_DIRECTORY_CITY=Portland
NEXT_PUBLIC_DIRECTORY_STATE=OR
NEXT_PUBLIC_DIRECTORY_TAGLINE=The directory for creatives, makers, and producers looking for monthly workspace.
