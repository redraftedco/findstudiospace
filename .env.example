# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Site identity
NEXT_PUBLIC_SITE_URL=https://www.findstudiospace.com
NEXT_PUBLIC_DIRECTORY_ID=
NEXT_PUBLIC_DIRECTORY_NAME=FindStudioSpace
NEXT_PUBLIC_DIRECTORY_DOMAIN=findstudiospace.com
NEXT_PUBLIC_DIRECTORY_TAGLINE=
NEXT_PUBLIC_DIRECTORY_CITY=Portland
NEXT_PUBLIC_DIRECTORY_STATE=OR

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY_ID=
STRIPE_PRICE_PRO_ANNUAL_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@findstudiospace.com

# CAN-SPAM physical mailing address (required before sending any outreach)
# Takes precedence over POSTAL_ADDRESS if both are set.
MAILING_ADDRESS=

# Postal address shown in footer and monthly digest
POSTAL_ADDRESS=

# Cron authentication
CRON_SECRET=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# View cookie signing
VIEW_COOKIE_SECRET=

# Supply acquisition
GOOGLE_PLACES_API_KEY=
APOLLO_API_KEY=          # optional — activates Apollo email enrichment fallback
OUTREACH_DAILY_CAP=20    # emails per send-outreach run (default 20)

# Platform notifications
PLATFORM_NOTIFY_EMAIL=
